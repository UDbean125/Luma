# ─── Luma Backend Environment ─────────────────────────────────────────────────

# PostgreSQL connection string
# Local:   postgres://postgres:password@localhost:5432/luma
# Render:  postgres://user:pass@host/luma
DATABASE_URL=postgres://postgres:password@localhost:5432/luma

# Port the API listens on
PORT=3001

# Public URL of this backend (used to build absolute media URLs)
# Local:      http://localhost:3001
# Production: https://luma-api.onrender.com
PUBLIC_API_BASE_URL=http://localhost:3001

# Set to "true" to enable demo fallback responses when DB has no data
ENABLE_DEMO_FALLBACK=true

# CORS — comma-separated allowed origins
# Add your Expo tunnel URL and production frontend URL here
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000,https://luma.hensolutions.com
