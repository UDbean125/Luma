# ─── Luma Frontend Environment ────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# For EAS builds, set these in eas.json build profiles or Expo dashboard secrets.

# Backend API base URL (no trailing slash)
# Dev:        http://localhost:3001
# Staging:    https://staging-api.luma.hensolutions.com
# Production: https://api.luma.hensolutions.com
EXPO_PUBLIC_SCENE_API_BASE_URL=

# Demo fallback — shows mock data when backend is unreachable
# Set to "false" for TestFlight / App Store production builds
EXPO_PUBLIC_ENABLE_DEMO_FALLBACK=true
